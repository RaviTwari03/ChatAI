// Duplicate this file as `Secrets.xcconfig` (kept out of Git) and fill in your private values.
// In Xcode: Select the ChatAI target -> Build Settings -> Info tab -> set the Config file for Debug/Release to Secrets.xcconfig
// Then the Info.plist will resolve $(VAR) placeholders below at build time.

// --- SMTP (Gmail example) ---
SMTP_HOST = smtp.gmail.com
SMTP_EMAIL = your.address@gmail.com
// For Gmail, use an App Password if 2-Step Verification is enabled. Do NOT use your account password.
SMTP_PASSWORD = your-app-password-16chars
// Defaults used if not set: 587 and TLS enabled
SMTP_PORT = 587
SMTP_TLS = YES

// --- Existing API keys (optional; leave blank if unused) ---
OPENAI_API_KEY =
XAI_API_KEY =
SUPABASE_URL =
SUPABASE_ANON_KEY =
